# ============================================================
# Smart Procurement System — Environment Variables
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
# ============================================================

# ---- Application ------------------------------------------
APP_NAME=Smart Procurement System
APP_VERSION=1.0.0
API_VERSION=v1
ENVIRONMENT=development        # development | production
DEBUG=True                     # set False in production
HOST=0.0.0.0
PORT=8000

# ---- Database (required) ----------------------------------
# Option A: full connection URL (preferred for Neon / hosted DBs)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/procurement

# Option B: individual fields (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=procurement

# ---- Authentication (required) ----------------------------
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ---- CORS -------------------------------------------------
# Comma-separated list of allowed frontend origins.
# In production with allow_origins=["*"] in main.py this is informational only.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- AI / Groq (required unless USE_MOCK_LLM=true) --------
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
MODEL_NAME=llama-3.1-8b-instant
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Set to true to run the chatbot without a Groq key.
# Intent classification uses keyword matching; responses are formatted
# directly from live DB queries. No torch/FAISS/external API calls.
USE_MOCK_LLM=false

# ---- Logging ----------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ---- File Uploads -----------------------------------------
MAX_FILE_SIZE=5242880   # 5 MB in bytes
UPLOAD_DIR=./uploads

# ---- Inventory Thresholds (optional overrides) ------------
# LOW_STOCK_THRESHOLD=10
# EXPIRY_WARNING_DAYS=90
# CRITICAL_EXPIRY_DAYS=30

# ---- Procurement (optional overrides) ---------------------
# AUTO_APPROVE_THRESHOLD=5000.0   # auto-approve POs below this amount (INR)
# VENDOR_RATING_THRESHOLD=3.5

# ---- AWS S3 (optional — for persistent file storage) ------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ---- WhatsApp (optional — integration not yet implemented) -
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
